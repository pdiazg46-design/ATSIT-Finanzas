{
  "name": "atsit-finance",
  "version": "1.0.0",
  "description": "ATSIT Finanzas - Aplicación de Control Financiero",
  "author": "AT-SIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pdiazg46-design/ATSIT-Finanzas.git"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.2.10",
    "get-port": "^7.1.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "next": "14.2.16",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.8",
    "electron": "33.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.atsit.finance",
    "productName": "ATSIT Finanzas",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/next/**/*",
      "**/node_modules/@libsql/**/*"
    ],
    "npmRebuild": false,
    "files": [
      "main.js",
      "package.json",
      "app/**/*",
      "components/**/*",
      "lib/**/*",
      "public/**/*",
      ".next/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "artifactName": "ATSIT-Finanzas-Setup-${version}.${ext}"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": ["zip"],
      "identity": null,
      "artifactName": "ATSIT-Finanzas-Mac-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ATSIT Finanzas"
    }
  }
}
